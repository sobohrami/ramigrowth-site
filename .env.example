# Public site URL (used for metadata / Open Graph)
NEXT_PUBLIC_SITE_URL=https://your-deployment.vercel.app

# Formspree form id (from https://formspree.io) — required for contact form submissions
NEXT_PUBLIC_FORMSPREE_FORM_ID=

# Optional: Calendly scheduling URL for “Book a discovery call” CTAs
NEXT_PUBLIC_CALENDLY_URL=

# Optional: shown in footer
NEXT_PUBLIC_CONTACT_EMAIL=
